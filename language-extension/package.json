{
  "name": "potato",
  "displayName": "potato",
  "description": "🥔💖✨",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.116.0"
  },
  "publisher": "dejmedus",
  "icon": "potato.png",
  "categories": [
    "Programming Languages"
  ],
  "repository": "github.com/dejmedus/potato",
  "main": "./out/client.js",
  "activationEvents": [
    "onLanguage:potato"
  ],
  "files": [
    "out/**",
    "server/**",
    "syntaxes/**",
    "language-configuration.json",
    "potato.png"
  ],
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ."
  },
  "contributes": {
    "languages": [
      {
        "id": "potato",
        "aliases": [
          "Potato",
          "potato"
        ],
        "extensions": [
          ".potato",
          ".tato",
          ".🥔"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./potato.png",
          "dark": "./potato.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "potato",
        "scopeName": "source.potato",
        "path": "./syntaxes/potato.tmLanguage.json"
      }
    ],
    "configurationDefaults": {
      "[potato]": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "dejmedus.potato"
      },
      "editor.tokenColorCustomizations": {
        "textMateRules": [
          {
            "scope": "operator.p.potato",
            "settings": {
              "foreground": "#ff6060"
            }
          },
          {
            "scope": "operator.o.potato",
            "settings": {
              "foreground": "#ffb326"
            }
          },
          {
            "scope": "operator.t1.potato",
            "settings": {
              "foreground": "#fa95ff"
            }
          },
          {
            "scope": "operator.a.potato",
            "settings": {
              "foreground": "#63f221"
            }
          },
          {
            "scope": "operator.t2.potato",
            "settings": {
              "foreground": "#45daff"
            }
          },
          {
            "scope": "operator.o2.potato",
            "settings": {
              "foreground": "#b255ff"
            }
          },
          {
            "scope": "comment.line.potato",
            "settings": {
              "foreground": "#aaaaaa"
            }
          },
          {
            "scope": [
              "keyword.operator.paren.begin.potato",
              "keyword.operator.paren.end.potato",
              "keyword.operator.paren.potato"
            ],
            "settings": {
              "foreground": "#383838",
              "fontStyle": "bold"
            }
          },
          {
            "scope": [
              "keyword.other.say.potato",
              "keyword.operator.is.potato",
              "keyword.operator.equals.potato",
              "keyword.operator.gains.potato",
              "keyword.operator.and.potato",
              "keyword.operator.or.potato",
              "keyword.operator.bigger.potato",
              "keyword.operator.atleast.potato"
            ],
            "settings": {
              "foreground": "#686868"
            }
          },
          {
            "scope": [
              "constant.numeric.potato",
              "string.quoted.double.potato"
            ],
            "settings": {
              "foreground": "#4d4d4d"
            }
          },
          {
            "scope": "keyword.operator.true.potato",
            "settings": {
              "foreground": "#aa8dff"
            }
          },
          {
            "scope": "keyword.operator.false.potato",
            "settings": {
              "foreground": "#6bceff"
            }
          }
        ]
      }
    }
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.116.0"
  }
}
