{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Potato",
  "scopeName": "source.potato",
  "patterns": [
    { "include": "#numbers" },
    { "include": "#strings" },
    { "include": "#say" },
    { "include": "#is" },
    { "include": "#equals" },
    { "include": "#gains" },
    { "include": "#true" },
    { "include": "#false" },
    { "include": "#and" },
    { "include": "#or" },
    { "include": "#bigger" },
    { "include": "#atleast" },
    { "include": "#parenthesis" },
    { "include": "#comment" },
    { "include": "#potato_rainbow" }
  ],
  "repository": {
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.potato",
          "match": "\"(?:\\\\.|[^\"])*\""
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.potato",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "say": {
      "patterns": [
        {
          "name": "keyword.other.say.potato",
          "match": "\\bsay\\b"
        }
      ]
    },
    "is": {
      "patterns": [
        {
          "name": "keyword.operator.is.potato",
          "match": "\\bis\\b"
        }
      ]
    },
    "equals": {
      "patterns": [
        {
          "name": "keyword.operator.equals.potato",
          "match": "equals\\?"
        }
      ]
    },
    "gains": {
      "patterns": [
        {
          "name": "keyword.operator.gains.potato",
          "match": "\\bgains\\b"
        }
      ]
    },
    "true": {
      "patterns": [
        {
          "name": "keyword.operator.true.potato",
          "match": ":\\)"
        }
      ]
    },
    "false": {
      "patterns": [
        {
          "name": "keyword.operator.false.potato",
          "match": ":\\("
        }
      ]
    },
    "and": {
      "patterns": [
        {
          "name": "keyword.operator.and.potato",
          "match": "\\band\\b"
        }
      ]
    },
    "or": {
      "patterns": [
        {
          "name": "keyword.operator.or.potato",
          "match": "\\bor\\b"
        }
      ]
    },
    "bigger": {
      "patterns": [
        {
          "name": "keyword.operator.bigger.potato",
          "match": "bigger\\?"
        }
      ]
    },
    "atleast": {
      "patterns": [
        {
          "name": "keyword.operator.atleast.potato",
          "match": "atleast\\?"
        }
      ]
    },
    "parenthesis": {
      "patterns": [
        {
          "name": "meta.parameters.potato",
          "begin": "(?<!:)\\(",
          "end": "(?<!:)\\)",
          "beginCaptures": {
            "0": { "name": "keyword.operator.paren.begin.potato" }
          },
          "endCaptures": {
            "0": { "name": "keyword.operator.paren.end.potato" }
          },
          "patterns": [
            { "include": "#strings" },
            { "include": "#numbers" },
            { "include": "#true" },
            { "include": "#false" }
          ]
        }
      ]
    },
    "comment": {
      "patterns": [
        {
          "name": "comment.line.potato",
          "match": "🍠.+"
        }
      ]
    },
    "potato_rainbow": {
      "patterns": [
        {
          "match": "\\b(p)(o)(t)(a)(t)(o)\\b",
          "captures": {
            "1": { "name": "operator.p.potato" },
            "2": { "name": "operator.o.potato" },
            "3": { "name": "operator.t1.potato" },
            "4": { "name": "operator.a.potato" },
            "5": { "name": "operator.t2.potato" },
            "6": { "name": "operator.o2.potato" }
          }
        }
      ]
    }
  }
}
